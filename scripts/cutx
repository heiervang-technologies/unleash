#!/usr/bin/env bash
# cutx - Agent Unleashed Wrapper (Headless tmux mode)
# NOTE: This script is kept as 'cutx' for backwards compatibility.
#       The new name is 'autx'. Both work identically.
#
# A headless mode for Claude using tmux instead of native headless.
# This allows interaction via key inputs and better session management.
#
# Usage:
#   autx start [args]     Start a new Claude session in tmux
#   autx send "message"   Send a message to Claude
#   autx read             Read current output from Claude
#   autx attach           Attach to the Claude tmux session
#   autx detach           Detach from session (when attached)
#   autx stop             Stop the Claude session
#   autx status           Check if session is running
#   autx "message"        Shorthand: send message and wait for response
#
# Environment:
#   AUTX_SESSION_NAME      tmux session name (default: agent-unleashed)
#   AUTX_WAIT_TIMEOUT      Seconds to wait for response (default: 300)
#   AUTX_TERM_WIDTH        Terminal width for tmux session (default: 200)
#   AUTX_TERM_HEIGHT       Terminal height for tmux session (default: 50)
#   AUTX_STABLE_THRESHOLD  Seconds of stable output to consider complete (default: 3)
#   AUTX_INIT_WAIT         Seconds to wait for Claude to initialize (default: 5)
#
# Legacy environment variables (CUTX_*) are still supported for backwards compatibility.
#
# Version: 1.3.0

set -uo pipefail

# Configuration (support both AUTX_* and legacy CUTX_* env vars)
SESSION_NAME="${AUTX_SESSION_NAME:-${CUTX_SESSION_NAME:-agent-unleashed}}"
WAIT_TIMEOUT="${AUTX_WAIT_TIMEOUT:-${CUTX_WAIT_TIMEOUT:-300}}"
TERM_WIDTH="${AUTX_TERM_WIDTH:-${CUTX_TERM_WIDTH:-200}}"
TERM_HEIGHT="${AUTX_TERM_HEIGHT:-${CUTX_TERM_HEIGHT:-50}}"
STABLE_THRESHOLD="${AUTX_STABLE_THRESHOLD:-${CUTX_STABLE_THRESHOLD:-3}}"
INIT_WAIT="${AUTX_INIT_WAIT:-${CUTX_INIT_WAIT:-5}}"
CACHE_DIR="${HOME}/.cache/agent-unleashed/autx"
OUTPUT_FILE="${CACHE_DIR}/${SESSION_NAME}.output"
MARKER_FILE="${CACHE_DIR}/${SESSION_NAME}.marker"
LOCK_FILE="${CACHE_DIR}/${SESSION_NAME}.lock"

# Validate session name (alphanumeric, underscore, dash only)
if [[ ! "$SESSION_NAME" =~ ^[a-zA-Z0-9_-]+$ ]]; then
    echo "Error: Invalid session name. Use alphanumeric, underscore, or dash only." >&2
    exit 1
fi

# Validate numeric environment variables
if ! [[ "$WAIT_TIMEOUT" =~ ^[0-9]+$ ]]; then
    echo "Error: CUTX_WAIT_TIMEOUT must be a positive integer (got: $WAIT_TIMEOUT)" >&2
    exit 1
fi
if ! [[ "$TERM_WIDTH" =~ ^[0-9]+$ ]]; then
    echo "Error: CUTX_TERM_WIDTH must be a positive integer (got: $TERM_WIDTH)" >&2
    exit 1
fi
if ! [[ "$TERM_HEIGHT" =~ ^[0-9]+$ ]]; then
    echo "Error: CUTX_TERM_HEIGHT must be a positive integer (got: $TERM_HEIGHT)" >&2
    exit 1
fi
if ! [[ "$STABLE_THRESHOLD" =~ ^[0-9]+$ ]]; then
    echo "Error: CUTX_STABLE_THRESHOLD must be a positive integer (got: $STABLE_THRESHOLD)" >&2
    exit 1
fi
if ! [[ "$INIT_WAIT" =~ ^[0-9]+$ ]]; then
    echo "Error: CUTX_INIT_WAIT must be a positive integer (got: $INIT_WAIT)" >&2
    exit 1
fi

# Get script directory for relative paths (portable, works on macOS and Linux)
SCRIPT_PATH="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)/$(basename "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(dirname "$SCRIPT_PATH")"

# Source shared onboarding library
source "${SCRIPT_DIR}/lib/onboarding.sh"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Ensure cache directory exists and is writable
if ! mkdir -p "$CACHE_DIR" 2>/dev/null; then
    echo "Error: Cannot create cache directory: $CACHE_DIR" >&2
    exit 1
fi
if ! [[ -w "$CACHE_DIR" ]]; then
    echo "Error: Cache directory is not writable: $CACHE_DIR" >&2
    exit 1
fi

log_info() {
    echo -e "${GREEN}[autx]${NC} $1"
}

log_warn() {
    echo -e "${YELLOW}[autx]${NC} $1"
}

log_error() {
    echo -e "${RED}[autx]${NC} $1" >&2
}

# Check if tmux is available
check_tmux() {
    if ! command -v tmux &>/dev/null; then
        log_error "tmux is required but not installed"
        return 1
    fi
}

# Check if Claude is available
check_claude() {
    local launcher="${SCRIPT_DIR}/au"
    if [[ -x "$launcher" ]]; then
        return 0
    fi
    if command -v au &>/dev/null; then
        return 0
    fi
    # Legacy: check for cu
    if command -v cu &>/dev/null; then
        return 0
    fi
    if command -v claude &>/dev/null; then
        return 0
    fi
    log_error "Neither au nor claude command found"
    return 1
}

# Check if session exists
session_exists() {
    tmux has-session -t "$SESSION_NAME" 2>/dev/null
}

# Start a new Claude session
cmd_start() {
    if ! check_tmux; then
        return 1
    fi
    if ! check_claude; then
        return 1
    fi

    if session_exists; then
        log_warn "Session '$SESSION_NAME' already exists"
        log_info "Use 'autx attach' to connect or 'autx stop' to restart"
        return 1
    fi

    # Acquire lock to prevent concurrent starts
    exec 200>"$LOCK_FILE"
    if ! flock -n 200; then
        log_error "Another autx start is in progress for session '$SESSION_NAME'"
        log_info "If this is an error, remove: $LOCK_FILE"
        return 1
    fi

    # Cleanup on error or interruption
    cleanup_on_error() {
        flock -u 200 2>/dev/null || true
        rm -f "$LOCK_FILE"
        tmux kill-session -t "$SESSION_NAME" 2>/dev/null || true
        rm -f "$OUTPUT_FILE" "$MARKER_FILE"
    }
    trap cleanup_on_error ERR INT TERM

    # Parse flags
    local auto_mode=false
    local daemon_mode=false
    local claude_args=()
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --auto|-a)
                auto_mode=true
                shift
                ;;
            -d|--daemon)
                daemon_mode=true
                shift
                ;;
            *)
                claude_args+=("$1")
                shift
                ;;
        esac
    done

    # Warn about conflicting flags
    if $auto_mode && $daemon_mode; then
        log_warn "Warning: --auto and -d/--daemon flags conflict"
        log_warn "Auto mode keeps Claude running indefinitely, preventing daemon mode cleanup"
        log_warn "The session will NOT auto-close when Claude exits"
    fi

    # Determine which launcher to use
    local launcher="${SCRIPT_DIR}/au"
    if [[ ! -x "$launcher" ]]; then
        launcher="au"
        if ! command -v "$launcher" &>/dev/null; then
            # Legacy: try cu
            launcher="cu"
            if ! command -v "$launcher" &>/dev/null; then
                launcher="claude"
            fi
        fi
    fi

    log_info "Starting Claude session '$SESSION_NAME'..."
    if $auto_mode; then
        log_info "Auto mode enabled"
    fi
    if $daemon_mode; then
        log_info "Daemon mode: session will close when Claude exits"
    fi

    # Ensure onboarding is complete before starting
    ensure_onboarding_complete "$launcher"

    # Clear previous output BEFORE starting pipe-pane to avoid race condition
    : > "$OUTPUT_FILE"

    # Create tmux session with configurable terminal size
    tmux new-session -d -s "$SESSION_NAME" -x "$TERM_WIDTH" -y "$TERM_HEIGHT"

    # Enable logging to capture output (after clearing file)
    tmux pipe-pane -t "$SESSION_NAME" -o "cat >> ${OUTPUT_FILE}"

    # Build command with optional auto mode env var
    local cmd=""
    if $auto_mode; then
        cmd="CLAUDE_AUTO_MODE=1 "
    fi
    cmd+="$launcher"
    if [[ ${#claude_args[@]} -gt 0 ]]; then
        cmd+=" $(printf '%q ' "${claude_args[@]}")"
    fi

    # In daemon mode, kill session when process exits
    if $daemon_mode; then
        cmd+="; tmux kill-session -t ${SESSION_NAME}"
    fi

    # Send command with properly quoted arguments to prevent injection
    tmux send-keys -t "$SESSION_NAME" "$cmd" Enter

    log_info "Session started. Use 'autx attach' to connect interactively"
    log_info "Or use 'autx send \"message\"' to send commands"
}

# Send a message to Claude
cmd_send() {
    if ! check_tmux; then
        return 1
    fi

    if ! session_exists; then
        log_error "No active session. Run 'autx start' first"
        return 1
    fi

    local message="$*"
    if [[ -z "$message" ]]; then
        log_error "No message provided"
        echo "Usage: autx send \"your message\""
        return 1
    fi

    # Record current output length as marker
    local marker
    marker=$(wc -c < "$OUTPUT_FILE" 2>/dev/null || echo 0)
    echo "$marker" > "$MARKER_FILE"

    # Send the message
    tmux send-keys -t "$SESSION_NAME" "$message" Enter

    log_info "Message sent"
}

# Read output from Claude
cmd_read() {
    if ! check_tmux; then
        return 1
    fi

    if [[ ! -f "$OUTPUT_FILE" ]]; then
        log_error "No output file found. Is a session running?"
        return 1
    fi

    # If marker exists, show only new output since last send
    if [[ -f "$MARKER_FILE" ]]; then
        local marker
        marker=$(cat "$MARKER_FILE")
        tail -c +$((marker + 1)) "$OUTPUT_FILE" 2>/dev/null
    else
        cat "$OUTPUT_FILE"
    fi
}

# Wait for Claude to finish responding
cmd_wait() {
    if ! check_tmux; then
        return 1
    fi

    if ! session_exists; then
        log_error "No active session"
        return 1
    fi

    local timeout="${1:-$WAIT_TIMEOUT}"
    local interval=1
    local elapsed=0
    local last_size=0
    local stable_count=0

    log_info "Waiting for response (timeout: ${timeout}s)..."

    while [[ $elapsed -lt $timeout ]]; do
        sleep $interval
        elapsed=$((elapsed + interval))

        # Check if session still exists
        if ! session_exists; then
            log_error "Session terminated unexpectedly"
            return 1
        fi

        local current_size
        current_size=$(wc -c < "$OUTPUT_FILE" 2>/dev/null || echo 0)

        if [[ "$current_size" -eq "$last_size" ]]; then
            stable_count=$((stable_count + 1))
            if [[ $stable_count -ge $STABLE_THRESHOLD ]]; then
                log_info "Response complete"
                return 0
            fi
        else
            stable_count=0
            last_size=$current_size
        fi
    done

    log_warn "Timeout reached"
    return 1
}

# Attach to the session
cmd_attach() {
    if ! check_tmux; then
        return 1
    fi

    if ! session_exists; then
        log_error "No active session. Run 'autx start' first"
        return 1
    fi

    local here=false
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --here|-h)
                here=true
                shift
                ;;
            *)
                shift
                ;;
        esac
    done

    if [[ -n "${TMUX:-}" ]]; then
        if $here; then
            # Join the Claude pane into current window
            log_info "Joining Claude pane into current window..."
            tmux join-pane -s "$SESSION_NAME:0.0" -h
        else
            log_info "Switching to session (prefix + ( or ) to switch back)..."
            tmux switch-client -t "$SESSION_NAME"
        fi
    else
        log_info "Attaching to session (Ctrl+B, D to detach)..."
        tmux attach-session -t "$SESSION_NAME"
    fi
}

# Stop the session
cmd_stop() {
    if ! check_tmux; then
        return 1
    fi

    if ! session_exists; then
        log_info "No active session"
        return 0
    fi

    log_info "Stopping session '$SESSION_NAME'..."
    tmux kill-session -t "$SESSION_NAME"
    rm -f "$OUTPUT_FILE" "$MARKER_FILE" "$LOCK_FILE"
    log_info "Session stopped"
}

# Check session status
cmd_status() {
    if ! check_tmux; then
        return 1
    fi

    if session_exists; then
        log_info "Session '$SESSION_NAME' is ${GREEN}running${NC}"

        # Show session info
        echo ""
        tmux list-sessions -F "#{session_name}: #{session_windows} windows, created #{session_created_string}" | grep "$SESSION_NAME" || true

        # Show recent output
        if [[ -f "$OUTPUT_FILE" ]] && [[ -s "$OUTPUT_FILE" ]]; then
            echo ""
            echo "Recent output (last 10 lines):"
            echo "─────────────────────────────"
            tail -n 10 "$OUTPUT_FILE"
        fi
    else
        log_info "Session '$SESSION_NAME' is ${RED}not running${NC}"
    fi
}

# Send message and wait for response (shorthand)
cmd_query() {
    local message="$*"

    # Start session if not running
    if ! session_exists; then
        cmd_start
        # Wait for Claude to initialize
        sleep "$INIT_WAIT"
    fi

    cmd_send "$message"
    cmd_wait
    echo ""
    echo "─────────────────────────────"
    cmd_read
}

# Show help
cmd_help() {
    cat << 'EOF'
autx - Agent Unleashed Wrapper (Headless tmux mode)
(Legacy name: cutx - still supported for backwards compatibility)

USAGE:
    autx <command> [args]
    autx "message"           Send message and wait for response

COMMANDS:
    start [--auto] [-d] [args]
                    Start a new Claude session in tmux
                    --auto: enable auto mode (Claude won't stop)
                    -d/--daemon: kill session when Claude exits
                    Additional args are passed to agent-unleashed

    send "msg"      Send a message to the running Claude session

    read            Read current output from Claude

    wait [secs]     Wait for Claude to finish responding
                    Default timeout: 300 seconds

    attach [--here] Attach to the Claude tmux session
                    --here: join pane into current window
                    Without --here: switch to session

    stop            Stop the Claude session

    status          Check if session is running and show info

    help            Show this help message

ENVIRONMENT:
    AUTX_SESSION_NAME      tmux session name (default: agent-unleashed)
                           Must contain only alphanumeric, underscore, or dash
    AUTX_WAIT_TIMEOUT      Default wait timeout in seconds (default: 300)
    AUTX_TERM_WIDTH        Terminal width for tmux session (default: 200)
    AUTX_TERM_HEIGHT       Terminal height for tmux session (default: 50)
    AUTX_STABLE_THRESHOLD  Seconds of stable output to consider response complete (default: 3)
    AUTX_INIT_WAIT         Seconds to wait for Claude to initialize (default: 5)

    Legacy environment variables (CUTX_*) are still supported for backwards compatibility.

EXAMPLES:
    # Start a session and send a message
    autx start
    autx send "Hello Claude, how are you?"
    autx wait
    autx read

    # Or use the shorthand
    autx "Hello Claude, how are you?"

    # Attach for interactive use
    autx attach

    # Start with specific arguments
    autx start --continue

    # Check status
    autx status

EOF
}

# Main dispatch
main() {
    local cmd="${1:-}"

    case "$cmd" in
        start)
            shift
            cmd_start "$@"
            ;;
        send)
            shift
            cmd_send "$@"
            ;;
        read)
            cmd_read
            ;;
        wait)
            shift
            cmd_wait "$@"
            ;;
        attach)
            shift
            cmd_attach "$@"
            ;;
        detach)
            log_info "Use Ctrl+B, D to detach from within tmux"
            ;;
        stop|kill)
            cmd_stop
            ;;
        status)
            cmd_status
            ;;
        help|--help|-h)
            cmd_help
            ;;
        "")
            cmd_help
            ;;
        *)
            # Treat as a message query
            cmd_query "$@"
            ;;
    esac
}

main "$@"
