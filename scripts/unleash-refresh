#!/usr/bin/env bash
# unleash-refresh - Trigger agent self-restart (preserves session)
#
# Usage: unleash-refresh [message]
#
# Requires: Running under unleash wrapper
# Note: Also available as 'restart-claude' (backward compat)

set -uo pipefail

CACHE_DIR="${HOME}/.cache/unleash/process-restart"

# Check if running under wrapper
if [[ -z "${AGENT_UNLEASH:-}" ]]; then
    echo "Error: Not running under unleash wrapper"
    echo "Start Claude with: unleash claude"
    exit 1
fi

# Get wrapper PID from environment (set by unleash wrapper)
WRAPPER_PID="${AGENT_WRAPPER_PID:-}"
if [[ -z "${WRAPPER_PID}" ]]; then
    echo "Error: AGENT_WRAPPER_PID not set"
    exit 1
fi

# Use wrapper-specific trigger files to avoid race conditions with concurrent instances
TRIGGER_FILE="${CACHE_DIR}/restart-trigger-${WRAPPER_PID}"
RESTART_MESSAGE_FILE="${CACHE_DIR}/restart-message-${WRAPPER_PID}"

# Find Claude's PID. Since unleash-refresh can be run from a background script (e.g., supercompact pipeline)
# where the process tree to the wrapper is broken, we must find the direct child of WRAPPER_PID
# instead of relying on $PPID.
CLAUDE_PID=$(pgrep -P "${WRAPPER_PID}" | head -n 1)

# Safety guard: Verify the process name to ensure we never kill critical system processes
if [[ -n "${CLAUDE_PID}" ]]; then
    CMD_NAME=$(ps -p "${CLAUDE_PID}" -o comm= 2>/dev/null || echo "unknown")
    if [[ "${CMD_NAME}" == "systemd" || "${CMD_NAME}" =~ "Hyprland" || "${CLAUDE_PID}" == "1" ]]; then
        echo "Error: Refusing to kill critical system process (${CMD_NAME}, PID ${CLAUDE_PID})"
        exit 1
    fi
fi

if [[ -z "${CLAUDE_PID}" ]]; then
    echo "Error: Could not determine Claude PID"
    exit 1
fi

# Verify process exists
if ! kill -0 "${CLAUDE_PID}" 2>/dev/null; then
    echo "Error: Claude process ${CLAUDE_PID} not running"
    exit 1
fi

# Save custom message if provided
if [[ $# -gt 0 ]]; then
    echo "$*" > "${RESTART_MESSAGE_FILE}"
fi

# Create trigger file
touch "${TRIGGER_FILE}"

# Kill Claude - wrapper will handle restart
kill -INT "${CLAUDE_PID}"
