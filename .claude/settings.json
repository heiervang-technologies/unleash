{
  "plugins": {
    "enabled": [
      "heiervang-snail-integration",
      "heiervang-workflows",
      "commit-commands",
      "feature-dev",
      "code-review",
      "mcp-refresh",
      "process-restart"
    ],
    "disabled": [],
    "mcp-refresh": {
      "autoDetect": true,
      "configPaths": [
        ".mcp.json",
        ".claude.json",
        "~/.claude.json"
      ]
    },
    "process-restart": {
      "preserveSession": true,
      "preserveWorkingDir": true,
      "preservePermissions": true,
      "stateFileExpiry": 300
    }
  },
  "defaults": {
    "model": "claude-sonnet-4-5",
    "temperature": 1.0
  },
  "organization": {
    "name": "heiervang-technologies",
    "github_org": "heiervang-technologies"
  },
  "snail": {
    "enabled": true,
    "auto_load_context": true,
    "github_integration": true
  }
}
