{
  "description": "Omnihook - Universal hook for low-latency voice message injection",
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "HOOK_EVENT=Stop ${CLAUDE_PLUGIN_ROOT}/hooks-handlers/omnihook-handler.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "HOOK_EVENT=PreToolUse ${CLAUDE_PLUGIN_ROOT}/hooks-handlers/omnihook-handler.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "HOOK_EVENT=PostToolUse ${CLAUDE_PLUGIN_ROOT}/hooks-handlers/omnihook-handler.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "HOOK_EVENT=Notification ${CLAUDE_PLUGIN_ROOT}/hooks-handlers/omnihook-handler.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "HOOK_EVENT=SessionStart ${CLAUDE_PLUGIN_ROOT}/hooks-handlers/omnihook-handler.sh"
          }
        ]
      }
    ]
  }
}
